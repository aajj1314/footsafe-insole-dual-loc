# ==================== 服务基础配置 ====================
SERVICE_NAME=device_terminal_service
DEBUG=false
HOST=0.0.0.0
LOG_LEVEL=INFO
LOG_FILE=logs/terminal_service.log
MAX_WORKERS=4

# ==================== 通信端口配置 ====================
UDP_PORT=8888
TCP_PORT=8889
TCP_MAX_CONNECTIONS=100000
TCP_CONNECTION_TIMEOUT=300

# ==================== 安全配置 ====================
ENCRYPTION_ENABLED=true
ENCRYPTION_ALGORITHM=AES-256-GCM
KEY_ROTATION_INTERVAL=604800

DEVICE_FINGERPRINT_ENABLED=true
MAX_AUTH_FAILURES=5
AUTH_LOCK_DURATION=3600

NONCE_EXPIRE_SECONDS=300
NONCE_CLEANUP_INTERVAL=600

# ==================== 重试配置 ====================
ALARM_RETRY_COUNT=3
ALARM_RETRY_INTERVAL_MS=1000
HEARTBEAT_RETRY_COUNT=2
TCP_HEARTBEAT_RETRY_COUNT=3
BATCH_RETRY_INTERVAL_MS=5000

# ==================== 会话配置 ====================
SESSION_EXPIRE_SECONDS=300
SESSION_ID_LENGTH=36

# ==================== 心跳配置 ====================
UDP_HEARTBEAT_INTERVAL=30
TCP_HEARTBEAT_INTERVAL=30
HEARTBEAT_EXPIRE_SECONDS=90

# ==================== 内存配置 ====================
OBJECT_POOL_MAX_SIZE=1000
OBJECT_POOL_IDLE_TIMEOUT=300

LOCAL_CACHE_MAX_SIZE=10000
LOCAL_CACHE_TTL=60
REDIS_CACHE_TTL=300

MAX_MEMORY_USAGE=536870912
MEMORY_MONITOR_INTERVAL=60

# ==================== 可靠性配置 ====================
MAX_REQUESTS_PER_SECOND=10
MAX_BATCH_SIZE=100

# ==================== 中间件配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=100
REDIS_POOL_MAX_OVERFLOW=200

MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_DATABASE=shoe_insole
MARIADB_USER=shoe_insole
MARIADB_PASSWORD=your_password
MARIADB_POOL_SIZE=50
MARIADB_POOL_MAX_OVERFLOW=100

# 为了向后兼容，保留MySQL环境变量
MYSQL_HOST=mariadb
MYSQL_PORT=3306
MYSQL_DATABASE=shoe_insole
MYSQL_USER=shoe_insole
MYSQL_PASSWORD=your_password
MYSQL_POOL_SIZE=50
MYSQL_POOL_MAX_OVERFLOW=100

INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your_token
INFLUXDB_ORG=shoe_insole
INFLUXDB_BUCKET=location
INFLUXDB_POOL_SIZE=20

# ==================== 预共享密钥（生产环境必须修改） ====================
DEVICE_PRESHARED_KEY=default_preshared_key_change_me
